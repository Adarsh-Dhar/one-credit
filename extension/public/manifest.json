{
  "manifest_version": 3,
  "name": "OneCredit - Optimize Your Payments",
  "version": "1.0.0",
  "description": "Automatically analyze your credit cards and find the best one for every purchase. Maximize rewards and minimize opportunity costs.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.walmart.com/*",
    "https://www.bestbuy.com/*",
    "https://www.target.com/*",
    "https://www.ebay.com/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.walmart.com/*",
        "https://www.bestbuy.com/*",
        "https://www.target.com/*",
        "https://www.ebay.com/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "OneCredit - Optimize Payments",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["js/*.js", "css/*.css"],
      "matches": [
        "https://www.amazon.com/*",
        "https://www.walmart.com/*",
        "https://www.bestbuy.com/*",
        "https://www.target.com/*",
        "https://www.ebay.com/*"
      ]
    }
  ]
}
