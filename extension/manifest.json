{
  "manifest_version": 3,
  "name": "OneCredit - AI Credit Card Optimizer",
  "version": "1.0.0",
  "description": "Get AI-powered credit card recommendations while shopping - detects products and shows which card costs the least in OP tokens",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self' http://localhost:3000 https://cdn.jsdelivr.net"
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.walmart.com/*",
    "https://www.bestbuy.com/*",
    "https://www.target.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://onecredit.app/*"
    ]
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.in/*",
        "https://www.walmart.com/*",
        "https://www.bestbuy.com/*",
        "https://www.target.com/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OneCredit Transaction Portal"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["https://www.amazon.com/*", "https://www.amazon.in/*", "https://www.walmart.com/*", "https://www.bestbuy.com/*", "https://www.target.com/*"]
    }
  ]
}
