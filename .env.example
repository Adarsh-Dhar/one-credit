# MongoDB
MONGODB_URI=mongodb://localhost:27017/omni-wallet

# Google Gemini AI
GOOGLE_API_KEY=your_gemini_api_key_here

# Fivetran
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_AIRLINE_CONNECTOR_ID=your_airline_connector_id
FIVETRAN_BANK_CONNECTOR_ID=your_bank_connector_id
FIVETRAN_HOTEL_CONNECTOR_ID=your_hotel_connector_id
FIVETRAN_REWARDS_CONNECTOR_ID=your_rewards_connector_id
# How often (seconds) to auto-sync the rewards mock APIs into MongoDB
FIVETRAN_REWARDS_SYNC_INTERVAL_SECONDS=300

# App
NODE_ENV=development
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Extension
NEXT_PUBLIC_EXTENSION_ID=your-extension-id-here

# MCP Server (path to Python server)
MCP_SERVER_PATH=./lib/mcp/fivetran-server.py

# Seed endpoint protection
SEED_SECRET=generate_with_openssl_rand_hex_32

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Development Origins (comma-separated list of allowed origins for dev)
ALLOWED_DEV_ORIGINS=192.168.29.73

# Dynatrace RUM (for persona inference)
DT_ENV_URL=https://<your-env-id>.live.dynatrace.com
DT_API_TOKEN=dt0c01.<token>
# Token needs scopes: logs.ingest + DataExport + UserSessionAccess (sessions.read)

# ─── Persona Cron Job ─────────────────────────────────────────────────────
# Shared secret — Vercel passes this automatically; self-hosted callers must
# include it as:  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate_with_openssl_rand_hex_32

# Cron schedule (standard 5-field cron expression, UTC by default).
# Examples:
#   "0 2 * * *"     → 02:00 every day (recommended for production)
#   "0 */6 * * *"   → every 6 hours
#   "*/15 * * * *"  → every 15 min (useful for local testing)
PERSONA_CRON_SCHEDULE=0 2 * * *

# Timezone for the standalone cron script (IANA format).
# The Vercel hosted cron always fires in UTC regardless of this value.
CRON_TIMEZONE=UTC

# Base URL for the standalone script to call back into the app.
# Not needed on Vercel (the platform calls the route directly).
APP_BASE_URL=http://localhost:3000

# Max users processed per cron invocation (keeps runtime within 300s limit).
PERSONA_CRON_BATCH_SIZE=50
